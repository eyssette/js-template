{
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"[javascript]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.formatOnSave": true
	},
	"[css]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.formatOnSave": true
	},
	"liveServer.settings.port": 5501,
	"liveServer.settings.root": "/dist",
	"editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
            "variable": {"underline": true },
            "variable.local": {"underline": false}, 
            "variable.defaultLibrary": {"underline": false}, 
            "property.declaration": {"underline": false}, 
        }
    },
	"eslint.validate": [
		".mjs",
		"javascript",
		"html",
		"markdown",
		"json"
	],
	"[feature]": {
		"editor.defaultFormatter": "alexkrechik.cucumberautocomplete",
		"editor.formatOnSave": true
	},
	"cognitiveComplexityShow.enabled": true,
	"cSpell.enabledFileTypes": {
		"javascript": false,
		"markdown": true,
		"json": true,
		"csv": true,
		"tsv": true,
		"txt": true,
		"html": true,
		"yaml": false,
	},
	"cSpell.language": "en,fr-FR,fr",
	"cSpell.words": [
		"Codecept",
		"codeceptjs",
		"ecma",
		"eyssette",
		"Gitlab",
		"jpegoptim",
		"lightningcss",
		"megalinter",
		"pngquant",
		"semgrep",
		"Taskfile",
		"trivy"
	],
	"cSpell.ignorePaths": [
		"package-lock.json",
		"node_modules",
		"vscode-extension",
		".git/{info,lfs,logs,refs,objects}/**",
		".git/{index,*refs,*HEAD}",
		".vscode",
		".vscode-insiders",
		".gitignore",
		"package.json"
	],
}
