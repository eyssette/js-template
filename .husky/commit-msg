#!/bin/bash

if ! cz check --allow-abort --commit-msg-file "$1" > /tmp/cz_output.txt 2>&1; then
  echo ""
  echo "❌ Message de commit invalide"
  echo ""
  echo "Format : <type>(<scope>): <description>"
  echo ""
  echo "Types principaux :"
  echo "  feat      nouvelle fonctionnalité (scope obligatoire)"
  echo "  fix       correction de bug (scope obligatoire)"
  echo "  edit      correction de coquilles / typos"
  echo "  docs      documentation"
  echo "  refactor  refactorisation"
  echo "  test      ajout/correction de tests"
  echo "  chore     autres changements"
  echo ""
  echo "Types supplémentaires autorisés :"
  echo "  style     changements sans impact sur le code"
  echo "  perf      amélioration de performance"
  echo "  build     système de build / dépendances"
  echo "  ci        configuration CI"
  echo ""
  echo "Le scope correspond à la partie du projet impactée par le commit."
  echo "Cela peut être un nom de module, de composant, de page, etc."
  echo ""
  exit 1
fi